*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
.venv/
env/
ENV/
env.bak/
venv.bak/

# ----------------------
# IDE & Editor
# ----------------------
.vs/
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ----------------------
# Testing & Coverage
# ----------------------
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/

# ----------------------
# Runtime & Generated
# ----------------------
